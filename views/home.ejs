<% layout("/layouts/boilerplate") %>

<!-- ================= HERO SECTION ================= -->

<section class="hero">

    <div class="hero-overlay"></div>

    <div class="container hero-content">

        <span class="hero-badge">
            ✈️ Discover • Book • Explore
        </span>

        <h1 class="hero-title">
            Welcome to <span>StaySphere</span>
        </h1>

        <p class="hero-subtitle">
            Luxury stays, unforgettable memories and unique experiences
            across the world. Find your perfect destination today.
        </p>

        <!-- Search Box -->

        <div class="search-box">

            <div class="search-item">

                <label>Destination</label>

                <input
                    type="text"
                    placeholder="Where are you going?"
                >

            </div>

            <div class="search-item">

                <label>Check In</label>

                <input type="date">

            </div>

            <div class="search-item">

                <label>Check Out</label>

                <input type="date">

            </div>

            <div class="search-item">

                <label>Guests</label>

            <select class="form-select hero-select">
                  <option>1 Guest</option>
                  <option>2 Guests</option>
                  <option>3 Guests</option>
                  <option>4 Guests</option>
            </select>

            </div>

            <button class="search-btn">

                <i class="fa-solid fa-magnifying-glass"></i>

                Explore

            </button>

        </div>

    </div>

</section>

<!-- ================= CATEGORIES ================= -->

<section class="categories">

    <div class="container">

        <div class="section-title">

            <h2>Browse by Category</h2>

            <p>
                Choose your dream stay based on your travel style.
            </p>

        </div>

        <div class="row g-4 mt-4">

            <div class="col-lg-2 col-md-4 col-6">

                <div class="category-card">

                    <i class="fa-solid fa-water"></i>

                    <h5>Beach</h5>

                </div>

            </div>

            <div class="col-lg-2 col-md-4 col-6">

                <div class="category-card">

                    <i class="fa-solid fa-mountain"></i>

                    <h5>Mountain</h5>

                </div>

            </div>

            <div class="col-lg-2 col-md-4 col-6">

                <div class="category-card">

                    <i class="fa-solid fa-house"></i>

                    <h5>Villa</h5>

                </div>

            </div>

            <div class="col-lg-2 col-md-4 col-6">

                <div class="category-card">

                    <i class="fa-solid fa-tree"></i>

                    <h5>Cabin</h5>

                </div>

            </div>

            <div class="col-lg-2 col-md-4 col-6">

                <div class="category-card">

                    <i class="fa-solid fa-water-ladder"></i>

                    <h5>Pool</h5>

                </div>

            </div>

            <div class="col-lg-2 col-md-4 col-6">

                <div class="category-card">

                    <i class="fa-solid fa-city"></i>

                    <h5>City</h5>

                </div>

            </div>

        </div>

    </div>

</section>

<!-- ================= STATS ================= -->

<section class="stats">

    <div class="container">

        <div class="row text-center">

            <div class="col-md-3">

                <div class="stat-box">

                    <h2>15K+</h2>

                    <p>Luxury Stays</p>

                </div>

            </div>

            <div class="col-md-3">

                <div class="stat-box">

                    <h2>120+</h2>

                    <p>Destinations</p>

                </div>

            </div>

            <div class="col-md-3">

                <div class="stat-box">

                    <h2>50K+</h2>

                    <p>Happy Travelers</p>

                </div>

            </div>

            <div class="col-md-3">

                <div class="stat-box">

                    <h2>4.9★</h2>

                    <p>Average Rating</p>

                </div>

            </div>

        </div>

    </div>

</section>
<!-- ================= ABOUT STAYSPHERE ================= -->

<section class="about-section">

    <div class="container">

        <div class="row align-items-center">

            <div class="col-lg-6">

                <img
                    src="https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?w=800"
                    class="img-fluid about-img"
                    alt="Luxury Stay">

            </div>

            <div class="col-lg-6">

                <span class="section-tag">
                    ABOUT US
                </span>

                <h2 class="section-heading">
                    Every Journey Begins With
                    <span>StaySphere</span>
                </h2>

                <p class="section-text">

                    StaySphere is more than just a booking platform.
                    We connect travelers with beautiful homes,
                    luxury villas, mountain cabins and unforgettable
                    destinations around the world.

                </p>

                <p class="section-text">

                    Whether you're planning a family vacation,
                    romantic getaway or solo adventure,
                    StaySphere helps you discover your perfect stay
                    with trusted hosts and premium experiences.

                </p>

                <a href="/listings" class="btn about-btn">
                    Discover More
                </a>

            </div>

        </div>

    </div>

</section>

