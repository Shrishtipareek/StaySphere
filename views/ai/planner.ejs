<% layout("/layouts/boilerplate") %>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

<link rel="stylesheet" href="/css/planner.css">


<!-- HERO -->

<section class="planner-hero">

    <div class="hero-overlay"></div>

    <div class="hero-card">

        <span class="hero-tag">
            ✨ AI Powered Luxury Planning
        </span>

        <h1>
            Design Your Dream Journey
        </h1>

        <p>

            Create personalized itineraries, optimize your travel budget,
            discover hidden gems and let AI craft unforgettable experiences.

        </p>

        <a href="#plannerForm" class="hero-btn">
            Start Planning
        </a>

    </div>

</section>



<!-- FEATURES -->

<section class="planner-features">

    <div class="section-title">

        <span>WHY CHOOSE AI?</span>

        <h2>Luxury Planning Made Effortless</h2>

    </div>


    <div class="feature-grid">

        <div class="feature-card">

            <div class="feature-icon">
                <i class="fa-solid fa-route"></i>
            </div>

            <h3>Smart Itinerary</h3>

            <p>

                AI generates personalized day-by-day plans based on your travel style.

            </p>

        </div>



        <div class="feature-card">

            <div class="feature-icon">
                <i class="fa-solid fa-wallet"></i>
            </div>

            <h3>Budget Optimizer</h3>

            <p>

                Get the perfect balance between luxury experiences and smart spending.

            </p>

        </div>



        <div class="feature-card">

            <div class="feature-icon">
                <i class="fa-solid fa-suitcase-rolling"></i>
            </div>

            <h3>Packing Assistant</h3>

            <p>

                Never miss essentials with an intelligent AI packing checklist.

            </p>

        </div>

    </div>

</section>
<div id="loadingScreen" class="loading-screen">

    <div class="loader"></div>

    <h2>StaySphere AI is crafting your luxury journey...</h2>

    <p>
        Finding hidden gems • Luxury hotels • Perfect restaurants
    </p>

</div>


<!-- Planner Form Starts Here -->

<section id="plannerForm">

<!-- Leave your existing form here.
DO NOT CHANGE IT YET. -->

</section>
<section id="plannerForm" class="planner-section">

    <div class="planner-container">

        <div class="planner-heading">

            <span>AI TRAVEL CONCIERGE</span>

            <h2>Craft Your Perfect Journey</h2>

            <p>
                Tell us your travel preferences and let AI create an unforgettable luxury experience.
            </p>

        </div>

        <form action="/ai/planner" method="POST" class="planner-form">

            <div class="input-grid">

                <div class="input-box">
                    <label>Destination</label>
                    <input
                        type="text"
                        name="destination"
                        placeholder="Paris, Bali, Kashmir..."
                        required>
                </div>

                <div class="input-box">
                    <label>Budget (₹)</label>
                    <input
                        type="number"
                        name="budget"
                        placeholder="50000">
                </div>

                <div class="input-box">
                    <label>Duration</label>

                    <select name="days">

                        <option>2 Days</option>
                        <option>3 Days</option>
                        <option>5 Days</option>
                        <option>7 Days</option>
                        <option>10 Days</option>

                    </select>

                </div>

                <div class="input-box">

                    <label>Travelers</label>

                    <select name="travellers">

                        <option>1 Person</option>
                        <option>2 People</option>
                        <option>Family</option>
                        <option>Friends</option>

                    </select>

                </div>

            </div>

            <div class="travel-style">

                <label>Travel Style</label>

                <div class="chip-group">

                    <label class="chip">
                        <input type="radio" name="style" value="Luxury">
                        Luxury
                    </label>

                    <label class="chip">
                        <input type="radio" name="style" value="Adventure">
                        Adventure
                    </label>

                    <label class="chip">
                        <input type="radio" name="style" value="Romantic">
                        Romantic
                    </label>

                    <label class="chip">
                        <input type="radio" name="style" value="Nature">
                        Nature
                    </label>

                    <label class="chip">
                        <input type="radio" name="style" value="Backpacking">
                        Backpacking
                    </label>

                </div>

            </div>

            <div class="textarea-box">

                <label>Special Requests</label>

                <textarea
                    rows="5"
                    name="extra"
                    placeholder="Luxury resorts, vegan food, beaches, nightlife, shopping..."></textarea>

            </div>

            <button class="generate-btn">

                <i class="fa-solid fa-wand-magic-sparkles"></i>

                Generate Luxury Itinerary

            </button>

        </form>

    </div>

</section>



   